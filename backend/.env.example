# Petone backend configuration. Copy to .env and fill in real values.
# Settings are read by app/config.py (pydantic-settings); env vars win over defaults.

# --- Core ---
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# --- Database ---
# Local dev falls back to SQLite if unset. Production: PostgreSQL via asyncpg.
DATABASE_URL=postgresql+asyncpg://petone:petone@localhost:5432/petone

# --- Security (REQUIRED in production) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=10

# --- CORS (JSON array — must list your production frontend origin) ---
CORS_ORIGINS=["https://petone.example.com"]

# --- Frontend (used for the payment-result redirect) ---
FRONTEND_URL=https://petone.example.com

# --- Payment gateway ---
# "fake" for dev/testing; "shaparak" once ShaparakGateway is implemented.
PAYMENT_GATEWAY=fake
SHAPARAK_BASE_URL=
SHAPARAK_MERCHANT_ID=

# --- SMS.ir (OTP provider) ---
# Leave empty in dev/CI — the OTP layer will log the code instead of sending.
# Never commit real values. Rotate the key from the SMS.ir panel if exposed.
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=0
SMSIR_BASE_URL=https://api.sms.ir
OTP_CODE_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
